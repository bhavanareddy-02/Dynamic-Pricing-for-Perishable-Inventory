# ─────────────────────────────────────────────────────────────────────
Datasets/
**/perishable_goods_management.csv
**/dunnhumby_The-Complete-Journey/

# Legacy notebooks — kept on disk for reference, not version-controlled
Code Files/

# Course deliverables that aren't part of the runnable repo
*.docx
*.pdf
*.pptx
*.mp4

# ─────────────────────────────────────────────────────────────────────
# Python
# ─────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
.eggs/
build/
dist/
.Python
.venv/
venv/
env/

